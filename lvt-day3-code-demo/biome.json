{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "files": {
    "ignore": ["**/dist", "**/node_modules", "**/.venv", "**/contracts"]
  },
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "formatter": { "enabled": true, "indentStyle": "space", "indentWidth": 2, "lineWidth": 110 },
  "organizeImports": { "enabled": true },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "security": { "noDangerouslySetInnerHtml": "off" },
      "suspicious": { "noExplicitAny": "off", "noEmptyBlockStatements": "off" },
      "style": { "noNonNullAssertion": "off" }
    }
  }
}
